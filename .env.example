# =============================================================================
# CacheSec — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
#
# This file holds ONLY infrastructure, secrets, and bootstrap settings.
# Everything else (camera type, detection thresholds, recording, Discord,
# Kinect/SLS, Tapo, etc.) is configured at runtime through the first-run
# setup wizard and the admin Settings page, and stored in the SQLite DB.
# -----------------------------------------------------------------------------

# -----------------------------------------------------------------------------
# Flask / Application
# -----------------------------------------------------------------------------
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_ME_IN_PRODUCTION
FLASK_ENV=production
# Bind address for the web server (keep on localhost; expose via Cloudflare
# or a reverse proxy). Docker compose forces 0.0.0.0 inside the container.
HOST=127.0.0.1
PORT=5000

# -----------------------------------------------------------------------------
# Storage paths
# -----------------------------------------------------------------------------
# These are filesystem locations and need to be set before the DB exists.
# In Docker, the compose file overrides them to /data/* on a named volume.
DATABASE_PATH=./cachesec.db
RECORDINGS_DIR=./recordings
SNAPSHOTS_DIR=./snapshots
UPLOAD_FOLDER=./uploads/faces
LOG_FILE=./logs/cachesec.log
LOG_LEVEL=INFO

# -----------------------------------------------------------------------------
# Hardware pin / device defaults
# -----------------------------------------------------------------------------
# Default V4L2 device index when CAMERA_PREFERRED_SOURCE=webcam. Container
# device passthrough usually maps the host node to /dev/video0, so 0 is fine.
CAMERA_INDEX=0
# GPIO pin for the access-denied buzzer (BCM numbering).
SOUND_GPIO_PIN=18

# -----------------------------------------------------------------------------
# Session / Security
# -----------------------------------------------------------------------------
# Set to true when behind HTTPS (Cloudflare Tunnel etc.). Set to false for
# plain HTTP on the LAN, or the dashboard's session cookie won't be sent.
SESSION_COOKIE_SECURE=true
SESSION_LIFETIME_MINUTES=60
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCKOUT_SECONDS=300
# Max upload size for face images, in bytes (default 5 MB).
MAX_CONTENT_LENGTH=5242880

# -----------------------------------------------------------------------------
# Cloudflare / Reverse Proxy
# -----------------------------------------------------------------------------
# Number of trusted proxy hops in front of CacheSec. Use 1 for Cloudflare
# Tunnel; 0 for direct local access (no proxy).
PROXY_COUNT=1
# Comma-separated allowed hostnames. Leave blank to allow any.
ALLOWED_HOSTS=

# -----------------------------------------------------------------------------
# Docker Compose overrides (optional, only used by docker-compose.yml)
# -----------------------------------------------------------------------------
# CACHESEC_IMAGE=cachesec:kinect
# INSTALL_KINECT=true
# CACHESEC_BIND_PORT=5000
# CACHESEC_VIDEO_DEVICE=/dev/video0
# CACHESEC_GPIO_DEVICE=/dev/gpiochip0

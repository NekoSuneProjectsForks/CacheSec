# =============================================================================
# CacheSec Face Recognition Security System - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# -----------------------------------------------------------------------------
# Flask / Application
# -----------------------------------------------------------------------------
SECRET_KEY=change-this-to-a-long-random-string-at-least-32-chars
FLASK_ENV=production
# Bind address for the web server (keep on localhost, expose via Cloudflare)
HOST=127.0.0.1
PORT=5000

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
DATABASE_PATH=./cachesec.db

# -----------------------------------------------------------------------------
# Face Recognition
# -----------------------------------------------------------------------------
# Cosine distance threshold (lower = stricter). 0.4 is a good default.
RECOGNITION_THRESHOLD=0.4
# How many frames to skip between full detection passes (reduces CPU)
FRAME_SKIP=3
# Camera index (0 = first USB cam / Pi cam)
CAMERA_INDEX=0
# webcam = try CAMERA_INDEX first; kinect = try Kinect/libfreenect first;
# ip = use IP_CAMERA_URL first.
CAMERA_PREFERRED_SOURCE=webcam
# RTSP, HTTP snapshot/stream, or MJPEG URL for wireless/IP cameras.
# Common examples:
#   rtsp://user:pass@192.168.1.50:554/stream1
#   http://192.168.1.50/video.mjpg
IP_CAMERA_URL=
# Extra live-only IP cameras, one per line or comma-separated.
# Format can be URL, Name|URL, or Name|URL|referer=https://site|origin=https://site
# with optional |user_agent=... overrides. Supports rtsp://, http(s) video/MJPEG/HLS,
# and http(s) snapshot image URLs.
IP_CAMERA_URLS=
# RTSP transport for IP_CAMERA_URL: tcp is most reliable over Wi-Fi.
IP_CAMERA_RTSP_TRANSPORT=tcp
# Optional ONVIF Imaging control for the primary IP camera.
# disabled = do nothing; detect = watch frame brightness and switch IrCutFilter
# on the camera between day/night modes.
IP_CAMERA_ONVIF_NIGHT_MODE=disabled
# Optional override; blank = reuse the host from IP_CAMERA_URL.
IP_CAMERA_ONVIF_HOST=
# Optional override; blank or 0 = use the HTTP(S) port from IP_CAMERA_URL when
# available, otherwise default to 80.
IP_CAMERA_ONVIF_PORT=0
# Optional overrides; blank = reuse credentials from IP_CAMERA_URL if present.
IP_CAMERA_ONVIF_USERNAME=
IP_CAMERA_ONVIF_PASSWORD=
# Advanced override; blank = auto-detect the WSDL folder installed by
# `onvif-zeep`.
IP_CAMERA_ONVIF_WSDL_DIR=

# -----------------------------------------------------------------------------
# TP-Link Tapo cameras (pytapo)
# -----------------------------------------------------------------------------
# Set CAMERA_PREFERRED_SOURCE=tapo to use a Tapo camera as the primary
# detection feed. pytapo speaks the camera's local HTTP API for PTZ,
# presets, and privacy-mode toggle. The video stream itself is RTSP.
#
# Use the "Camera Account" set in the Tapo app under
#   Advanced Settings → Camera Account
# (NOT the Tapo cloud login).
TAPO_HOST=
TAPO_USERNAME=admin
TAPO_PASSWORD=
# Optional. Some firmware versions require the Tapo cloud password to
# authorise PTZ/preset commands. Leave blank if unsure.
TAPO_CLOUD_PASSWORD=
# stream1 = high quality, stream2 = low quality.
TAPO_STREAM=stream1

# Frame width/height for capture
FRAME_WIDTH=640
FRAME_HEIGHT=480
# Seconds of no unknown face before the ongoing event is considered ended
UNKNOWN_COOLDOWN_SECONDS=10

# -----------------------------------------------------------------------------
# Recording
# -----------------------------------------------------------------------------
RECORDINGS_DIR=./recordings
SNAPSHOTS_DIR=./snapshots
MIN_RECORDING_SECONDS=15
MAX_RECORDING_SECONDS=5400
# true = keep completed videos in RECORDINGS_DIR; false = upload finished clips
# to Discord only, then delete local temp/video files
SAVE_RECORDINGS_LOCALLY=true
# Off by default. If true, ffmpeg/ALSA will try to capture audio from a detected
# Kinect 360, webcam, USB microphone, or the system default microphone.
RECORD_AUDIO_ENABLED=false
# auto = prefer IP_CAMERA_URL audio when CAMERA_PREFERRED_SOURCE=ip, otherwise
# detected Kinect/webcam/USB mic. You can override with ALSA names such as
# default, plughw:2,0, hw:2,0, or a separate rtsp/http audio stream URL.
RECORD_AUDIO_DEVICE=auto

# -----------------------------------------------------------------------------
# Discord Webhook
# -----------------------------------------------------------------------------
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_ID/YOUR_TOKEN
# Seconds between webhook alerts for the same continuous event
DISCORD_COOLDOWN_SECONDS=60
# Set true to include @everyone in unknown-person Discord alerts.
DISCORD_MENTION_EVERYONE=false

# -----------------------------------------------------------------------------
# Sound
# -----------------------------------------------------------------------------
# Set to false to disable GPIO buzzer sounds
SOUND_ENABLED=true
# GPIO pin for PWM speaker (BCM numbering)
SOUND_GPIO_PIN=18

# -----------------------------------------------------------------------------
# Kinect / SLS
# -----------------------------------------------------------------------------
# Kinect v1 support uses libfreenect for RGB/IR/depth.
KINECT_ENABLED=true
# Motor tilt in degrees (-27 to +27)
KINECT_TILT=0
# Leave false for SLS unless you specifically need tilt/LED control.
KINECT_MOTOR_ENABLED=false
# When the main webcam gets dark, switch to Kinect IR/depth night vision.
KINECT_NIGHT_VISION_ENABLED=true
# SLS overlays stick figures from Kinect depth data.
SLS_ENABLED=true
# night = only overlay in Kinect IR/night mode; always = keep Kinect in IR/SLS mode.
SLS_MODE=night
SLS_MAX_PEOPLE=4

# -----------------------------------------------------------------------------
# Uploads
# -----------------------------------------------------------------------------
UPLOAD_FOLDER=./uploads/faces
# Max file size for uploaded face images (bytes) - default 5 MB
MAX_CONTENT_LENGTH=5242880

# -----------------------------------------------------------------------------
# Session / Security
# -----------------------------------------------------------------------------
# Session lifetime in minutes
SESSION_LIFETIME_MINUTES=60
# Set to true when running behind Cloudflare HTTPS.
# For local Docker Compose / LAN HTTP, set this to false.
SESSION_COOKIE_SECURE=true
# Max failed login attempts before lockout
LOGIN_MAX_ATTEMPTS=5
# Lockout duration in seconds
LOGIN_LOCKOUT_SECONDS=300

# -----------------------------------------------------------------------------
# Cloudflare / Proxy
# -----------------------------------------------------------------------------
# Number of trusted proxy hops (1 for Cloudflare Tunnel)
# For local Docker Compose with no reverse proxy, use 0.
PROXY_COUNT=1
# Allowed hostnames (comma-separated). Leave blank to allow any.
ALLOWED_HOSTS=

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
LOG_LEVEL=INFO
LOG_FILE=./logs/cachesec.log

# -----------------------------------------------------------------------------
# Docker Compose overrides (optional)
# -----------------------------------------------------------------------------
# These are only used by docker-compose.yml. The app ignores them.
# CACHESEC_IMAGE=cachesec:kinect
# INSTALL_KINECT=true
# CACHESEC_BIND_PORT=5000
# CACHESEC_SESSION_COOKIE_SECURE=false
# CACHESEC_PROXY_COUNT=0
# Host device paths to pass through when the docker-compose.yml devices section
# is enabled. Keep CAMERA_INDEX=0 when mapping the selected host video node to
# /dev/video0 inside the container.
# CACHESEC_VIDEO_DEVICE=/dev/video0
# CACHESEC_GPIO_DEVICE=/dev/gpiochip0
